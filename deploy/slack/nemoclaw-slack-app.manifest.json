{
  "display_information": {
    "name": "NemoClaw",
    "description": "NemoClaw ops agent — approvals + conversational ops",
    "background_color": "#1a1526"
  },
  "features": {
    "bot_user": {
      "display_name": "NemoClaw",
      "always_online": true
    },
    "app_home": {
      "home_tab_enabled": true,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "assistant_view": {
      "assistant_description": "NemoClaw connects Slack threads to the ops agent.",
      "suggested_prompts": [
        { "title": "What can you do?", "message": "What can you help me with?" },
        { "title": "Cluster health", "message": "Give me a current cluster health summary." },
        { "title": "Diagnose latest alert", "message": "Diagnose the most recent alert and propose a fix." }
      ]
    },
    "slash_commands": [
      {
        "command": "/nemoclaw",
        "description": "Send a message to NemoClaw",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "assistant:write",
        "channels:history",
        "channels:read",
        "chat:write",
        "chat:write.customize",
        "commands",
        "emoji:read",
        "files:read",
        "files:write",
        "groups:history",
        "groups:read",
        "im:history",
        "im:read",
        "im:write",
        "mpim:history",
        "mpim:read",
        "mpim:write",
        "pins:read",
        "pins:write",
        "reactions:read",
        "reactions:write",
        "usergroups:read",
        "users:read"
      ]
    }
  },
  "settings": {
    "socket_mode_enabled": true,
    "event_subscriptions": {
      "bot_events": [
        "app_home_opened",
        "app_mention",
        "assistant_thread_context_changed",
        "assistant_thread_started",
        "channel_rename",
        "member_joined_channel",
        "member_left_channel",
        "message.channels",
        "message.groups",
        "message.im",
        "message.mpim",
        "pin_added",
        "pin_removed",
        "reaction_added",
        "reaction_removed"
      ]
    },
    "org_deploy_enabled": false,
    "token_rotation_enabled": false
  }
}
